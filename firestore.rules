rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string (optional)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // Collection: farmers
    // Document ID: {farmerId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - phone: string (required)
    //   - location: string (optional)
    //   - joinedAt: timestamp (required)
    //
    // Collection: collections
    // Document ID: {collectionId}
    // Fields:
    //   - id: string (required)
    //   - farmerId: string (required)
    //   - amount: number (required)
    //   - quality: number (optional)
    //   - timestamp: timestamp (required)
    //   - collectedBy: string (required, uid)
    //
    // Collection: payments
    // Document ID: {paymentId}
    // Fields:
    //   - id: string (required)
    //   - farmerId: string (required)
    //   - amount: number (required)
    //   - period: string (required, e.g., '2026-03')
    //   - status: string (required, enum: ['pending', 'paid'])
    //   - timestamp: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "Billmatoya@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidFarmer(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'joinedAt']) &&
             data.id is string &&
             data.name is string &&
             data.phone is string &&
             data.joinedAt is timestamp;
    }

    function isValidCollection(data) {
      return data.keys().hasAll(['id', 'farmerId', 'amount', 'timestamp', 'collectedBy']) &&
             data.id is string &&
             data.farmerId is string &&
             data.amount is number &&
             data.timestamp is timestamp &&
             data.collectedBy is string;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'farmerId', 'amount', 'period', 'status', 'timestamp']) &&
             data.id is string &&
             data.farmerId is string &&
             data.amount is number &&
             data.period is string &&
             data.status in ['pending', 'paid'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(uid) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(uid) || isAdmin()) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /farmers/{farmerId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidFarmer(request.resource.data);
      allow update: if isAdmin() && isValidFarmer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /collections/{collectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCollection(request.resource.data) && (isAdmin() || request.resource.data.collectedBy == request.auth.uid);
      allow update: if isAdmin() && isValidCollection(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidPayment(request.resource.data);
      allow update: if isAdmin() && isValidPayment(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
